# ═══════════════════════════════════════════════════════════════
# SmartSafety+ Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=smartsafety

# ── Security ──────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── AI / LLM (OpenAI-compatible) ─────────────────────────────
EMERGENT_LLM_KEY=sk-your-openai-key-here

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# ── SMS (Twilio) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
